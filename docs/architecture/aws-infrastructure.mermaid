graph TD
    %% Internet/Users Layer
    User((User / Recruiter))
    DNS["Route 53 (DNS)"]

    %% AWS VPC Layer
    subgraph VPC ["AWS VPC"]
        %% Public Subnet
        subgraph PublicSubnet ["Public Subnet"]
            IGW["Internet Gateway"]
            Nginx["Nginx Reverse Proxy\n(HTTPS/SSL)"]
            EC2["EC2 Instance (t3.medium)"]
        end

        %% Private Services
        subgraph DockerServices ["Docker Containers (EC2)"]
            Backend["Spring Boot Backend"]
            Frontend["React Frontend"]
            Prometheus["Prometheus"]
            Grafana["Grafana"]
            n8n["n8n Server"]
        end

        %% Managed Services
        RDS[(AWS RDS PostgreSQL)]
    end

    %% External AWS Services
    S3["AWS S3 Bucket\n(Resume Storage)"]
    ECR["AWS ECR\n(Container Registry)"]
    CloudWatch["AWS CloudWatch\n(Logs & Metrics)"]

    %% Connections
    User -- HTTPS --> DNS
    DNS --> IGW
    IGW --> Nginx
    Nginx --> Frontend
    Nginx --> Backend
    Nginx --> Grafana

    Backend -- "JDBC/TLS" --> RDS
    Backend -- "AWS SDK" --> S3
    Backend -- "Logs" --> CloudWatch
    DockerServices -. "Pulls images" .-> ECR
